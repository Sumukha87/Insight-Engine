# Copy to .env and fill in values
# .env is gitignored — never commit real values

# Neo4j
NEO4J_PASSWORD=changeme_strong_password

# PostgreSQL
POSTGRES_USER=insight_engine
POSTGRES_PASSWORD=changeme_postgres
# DATABASE_URL is constructed automatically in docker-compose — no need to set manually

# pgAdmin (GUI at http://localhost:5050)
PGADMIN_EMAIL=admin@insight-engine.local
PGADMIN_PASSWORD=changeme_pgadmin

# Auth
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key_32_bytes_hex
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Grafana
GRAFANA_PASSWORD=changeme_grafana

# App settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Ollama (running natively in WSL2, not in Docker)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=insight-engine-prototype

# DVC
DVC_CACHE_TYPE=symlink
